{
	"name": "shelflare",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings",
		"build": "cd frontend && pnpm build",
		"dev:frontend": "cd frontend && pnpm dev",
		"lint": "biome check src/",
		"lint:fix": "biome check --write src/",
		"typecheck": "tsc --noEmit",
		"typecheck:frontend": "cd frontend && pnpm tsc -b",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply shelflare-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply shelflare-db --remote"
	},
	"dependencies": {
		"@ai-sdk/openai-compatible": "^2.0.48",
		"ai": "^6.0.191",
		"diff": "^8.0.4",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.18",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "^25.8.0",
		"drizzle-kit": "^0.31.10",
		"typescript": "^6.0.3",
		"wrangler": "^4.91.0"
	}
}
